         return AVERROR(errno);
     h->is_streamed = !(S_ISREG(st.st_mode) || S_ISBLK(st.st_mode));
     c->fd = fd_dup(h, c->fd);
@@ -627,8 +616,8 @@ static int android_content_open(URLContext *h, const char *filename, int flags)
     if (ret < 0)
         goto done;
 
-    if (fstat(fd, &st) < 0) {
-        close(fd);
+    if (fstat(fd, &st) < 0) { // fio-safe: android content protocol
+        close(fd); // fio-safe: android content protocol
         return AVERROR(errno);
     }
 
